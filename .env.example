# MindStudio Insight 环境变量配置

# 方式一：使用 Cloudflare Worker（推荐用于生产环境）
# Worker 地址，部署后从 Cloudflare 获取
NEXT_PUBLIC_WORKER_URL=https://your-worker.workers.dev

# 方式二：直连 SiliconFlow API（仅用于开发环境）
# 从 https://cloud.siliconflow.cn/account/ak 获取
NEXT_PUBLIC_API_KEY=your-api-key-here

# 注意：
# 1. 生产环境建议使用方式一（Worker），API Key 保存在服务端更安全
# 2. 开发环境可以使用方式二（直连），方便调试
# 3. 两种方式只需配置一种
